{
  "name": "LocalLedger",
  // Instead of dockerComposeFile, we point directly to an image
  "image": "mcr.microsoft.com/devcontainers/base:ubuntu",

  // Features allow you to add languages/tools without a Dockerfile
  "features": {
    "ghcr.io/devcontainers/features/common-utils:1": {
      "configureZshAsDefaultShell": true
    },
    "ghcr.io/devcontainers/features/node:1": {
      "version": "22"
    },
    "ghcr.io/devcontainers/features/rust:1": {}
  },

  "customizations": {
    "vscode": {
      "settings": {
        "editor.formatOnSave": true,
        "editor.defaultFormatter": "esbenp.prettier-vscode",
        "rust-analyzer.check.command": "clippy",
        "[rust]": {
          "editor.defaultFormatter": "rust-lang.rust-analyzer"
        },
        "editor.codeActionsOnSave": {
          "source.fixAll.eslint": "explicit",
          "source.organizeImports": "explicit"
        },
        "javascript.updateImportsOnFileMove.enabled": "always",
        "typescript.updateImportsOnFileMove.enabled": "always"
      },
      "extensions": [
        "googlecloudtools.cloudcode",
        "dbaeumer.vscode-eslint",
        "esbenp.prettier-vscode",
        "editorconfig.editorconfig",
        "christian-kohler.npm-intellisense",
        "rust-lang.rust-analyzer",
        "tamasfe.even-better-toml",
        "alexcvzz.vscode-sqlite"
      ]
    }
  },

  // Standard devcontainer user
  "remoteUser": "vscode",
  "postCreateCommand": "npm install -g @google/gemini-cli && sudo apt-get update && sudo apt-get install -y sqlite3 && git config --global include.path /workspaces/LocalLedger/.gitconfig"
}
